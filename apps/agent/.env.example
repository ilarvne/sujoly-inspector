# Ollama Configuration
AGENT_OLLAMA_BASE_URL=http://localhost:11434
AGENT_OLLAMA_MODEL=qwen3:4b
AGENT_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
AGENT_OLLAMA_TEMPERATURE=0.1
AGENT_OLLAMA_NUM_PREDICT=512

# ChromaDB Configuration
AGENT_CHROMA_PERSIST_DIRECTORY=./data/chroma
AGENT_CHROMA_COLLECTION_NAME=agent_memory

# Agent Configuration
AGENT_AGENT_NAME=Agent
AGENT_AGENT_MAX_ITERATIONS=10

# NVIDIA NIM Configuration
AGENT_NVIDIA_API_KEY=nvapi-xxx
AGENT_NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
AGENT_NVIDIA_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
AGENT_NVIDIA_RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2
AGENT_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Agent API authentication (optional)
# Single key
AGENT_AGENT_API_KEY=
# Comma-separated keys for rotation
AGENT_AGENT_API_KEYS=
