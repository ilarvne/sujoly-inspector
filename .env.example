# =============================================================================
# Zhambyl Hydraulic Structures Catalog — Environment Variables (Template)
# =============================================================================
# Copy this file to .env and fill with real values.
# NEVER commit the real .env file.

# ---- API (Backend FastAPI) ----
# Local Docker defaults — these match docker-compose.yml service hostnames.
# Remote alem.ai credentials for production — set in .env, NOT here.
API_DATABASE_URL=postgresql+asyncpg://sujoly:sujoly_dev@postgres:5432/sujoly
API_SYNC_DATABASE_URL=postgresql://sujoly:sujoly_dev@postgres:5432/sujoly
API_REDIS_URL=redis://redis:6379/0
API_MINIO_ENDPOINT=minio:9000
API_MINIO_ACCESS_KEY=minioadmin
API_MINIO_SECRET_KEY=minioadmin
API_MINIO_USE_SSL=false
API_ALLOWED_ORIGINS=http://localhost:3000

# ---- PostgreSQL / PostGIS ----
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB

# ---- MinIO (S3-compatible object storage) ----
MINIO_ENDPOINT=
MINIO_S3_URL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_USE_SSL=true

# ---- Redis (caching / job queues) ----
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=
REDIS_URL=redis://:PASSWORD@HOST:PORT/DB

# ---- Milvus (vector similarity search) ----
MILVUS_HOST=
MILVUS_PORT=
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DB=
MILVUS_URL=

# ---- RAGFlow ----
RAGFLOW_URL=
RAGFLOW_EMAIL=
RAGFLOW_PASSWORD=

# =============================================================================
# Alem LLM API Services
# =============================================================================

# ---- Base URL ----
LLM_BASE_URL=https://llm.alem.ai/v1

# ---- Reranker API ----
RERANKER_API_KEY=
RERANKER_MODEL=reranker
RERANKER_URL=https://llm.alem.ai/v1/rerank

# ---- OCR API (deepseek-ocr) ----
OCR_API_KEY=
OCR_MODEL=deepseek-ocr
OCR_URL=https://llm.alem.ai/v1/chat/completions

# ---- Speech-to-Text (English) ----
STT_EN_API_KEY=
STT_EN_MODEL=speech-to-text
STT_EN_URL=https://llm.alem.ai/v1/audio/transcriptions

# ---- Speech-to-Text (Kazakh) ----
STT_KK_API_KEY=
STT_KK_MODEL=speech-to-text-kk
STT_KK_URL=https://llm.alem.ai/v1/audio/transcriptions

# ---- Embeddings API ----
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-1024
EMBEDDINGS_URL=https://llm.alem.ai/v1/embeddings

# ---- Chat API: Qwen3-6 ----
CHAT_QWEN_API_KEY=
CHAT_QWEN_MODEL=qwen3-6
CHAT_QWEN_URL=https://llm.alem.ai/v1/chat/completions

# ---- Chat API: Gemma4 ----
CHAT_GEMMA_API_KEY=
CHAT_GEMMA_MODEL=gemma4
CHAT_GEMMA_URL=https://llm.alem.ai/v1/chat/completions

# ---- Chat API: AlemLLM ----
CHAT_ALEM_API_KEY=
CHAT_ALEM_MODEL=alemllm
CHAT_ALEM_URL=https://llm.alem.ai/v1/chat/completions

# =============================================================================
# Application defaults
# =============================================================================

# Default LLM model for copilot / general chat
LLM_DEFAULT_MODEL=qwen3-6
LLM_DEFAULT_API_KEY=

# Default embedding model for vector search
EMBEDDING_DEFAULT_MODEL=text-1024
EMBEDDING_DEFAULT_API_KEY=

# App environment
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAP_TILES_URL=http://localhost:8001
